{
  "manifest_version": 3,
  "name": "Panop Android Extension",
  "version": "1.0.0",
  "description": "Automatically monitors and routes academic and specific pages directly to KMS/Zotero.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "scripting",
    "sessions"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Panop Settings"
  }
}
